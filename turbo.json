{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".cache/tsbuildinfo.json", "dist/**", "build/**"]
    },
    "//#lint": {},
    "//#lint:fix": {
      "cache": false
    },
    "//#format": {},
    "//#format:fix": {
      "cache": false
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": false
    },
    "clean": {
      "cache": false
    },
    "setup": {
      "cache": false,
      "dependsOn": ["@workspace/db#db:setup"]
    },
    "test": {
      "outputs": ["coverage.json"]
    }
  },
  "globalEnv": [
    "DATABASE_URL",
    "PRODUCT_NAME",
    "URL",
    "DEFAULT_LOCALE",
    "REPORT_AGENT_URL",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "GITHUB_CLIENT_ID",
    "GITHUB_CLIENT_SECRET",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "STRIPE_PUBLISHABLE_KEY",
    "NEXT_PUBLIC_URL",
    "NEXT_PUBLIC_PRODUCT_NAME",
    "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
    "EMAIL_FROM",
    "CONTACT_EMAIL",
    "S3_ENDPOINT",
    "S3_ACCESS_KEY_ID",
    "S3_SECRET_ACCESS_KEY",
    "NODEMAILER_HOST",
    "NODEMAILER_PORT",
    "NODEMAILER_USER",
    "NODEMAILER_PASSWORD",
    "DEEPSEEK_API_KEY"
  ],
  "globalPassThroughEnv": [
    "NODE_ENV",
    "SKIP_ENV_VALIDATION",
    "npm_lifecycle_event"
  ]
}
