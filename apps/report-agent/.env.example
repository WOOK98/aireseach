# 报告生成模式：deep_research 或 jina_llm
REPORT_MODE=jina_llm

# Perplexity 深度研究模式
PERPLEXITY_API_KEY=
AGENT_BASE_URL=https://api.perplexity.ai
AGENT_MODEL=sonar-deep-research

# Jina + LLM 模式
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# Jina 搜索
JINA_API_KEY=
JINA_SEARCH_BASE_URL=https://s.jina.ai/
SEARCH_TIMEOUT_SECONDS=20
SEARCH_CONTEXT_CHARS=12000

# CORS（逗号分隔）
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001
